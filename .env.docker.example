# Copy to ".env" next to docker-compose.yml (or set these in the Portainer stack UI).
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o

# Reverse proxy gets its own LAN IP on an existing macvlan network.
LAN_NETWORK=net1010
PROXY_IP=10.10.10.63
# → browse the app at http://10.10.10.63

# Optional HTTP Basic Auth on the whole site (app + /api). Set BOTH to enable,
# leave empty/unset to keep the site open.
BASIC_AUTH_USER=admin
BASIC_AUTH_PASSWORD=change-me
